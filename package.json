{
  "name": "stellarexplorer",
  "description": "Ledger explorer for the Stellar network",
  "version": "3.1.3",
  "type": "module",
  "license": "Apache-2.0",
  "author": "Chris Hatch <devcebfaff@proton.me>",
  "homepage": "https://steexp.com",
  "repository": "chatch/stellarexplorer",
  "bugs": {
    "url": "https://github.com/chatch/stellarexplorer/issues"
  },
  "keywords": [
    "stellar",
    "react",
    "ledger",
    "soroban",
    "smart contract",
    "remix.run",
    "block explorer",
    "blockchain"
  ],
  "engines": {
    "node": ">= 24.0.0"
  },
  "packageManager": "pnpm@11.8.0",
  "sideEffects": false,
  "scripts": {
    "build": "remix vite:build",
    "build:decentralized": "STEEXP_BUILD_TARGET=decentralized remix vite:build && node scripts/patch-decentralized-remix-manifest.mjs",
    "dev": "remix vite:dev",
    "start": "vite preview",
    "pages:dev": "wrangler pages dev ./build/client",
    "pages:deploy": "pnpm run build && wrangler pages deploy ./build/client --branch master",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "lint:fix": "eslint --cache --cache-location ./node_modules/.cache/eslint --fix . || true",
    "prettier": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "prettier:fix": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "fixstyle": "pnpm prettier:fix",
    "fixall": "npm-run-all prettier:fix lint:fix",
    "typecheck": "tsc",
    "test": "jest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@remix-run/css-bundle": "2.17.5",
    "@remix-run/node": "2.17.5",
    "@remix-run/react": "2.17.5",
    "@remix-run/server-runtime": "2.17.5",
    "@sentry/remix": "10.63.0",
    "@stellar/js-xdr": "4.0.0",
    "@stellar/stellar-sdk": "16.0.1",
    "bignumber.js": "^11.1.4",
    "bootstrap": "^5.3.8",
    "js-cookie": "^3.0.8",
    "lodash": "^4.18.1",
    "p-retry": "^8.0.0",
    "prismjs": "^1.30.0",
    "prop-types": "15.8.1",
    "react": "18.3.1",
    "react-bootstrap": "2.10.10",
    "react-dom": "18.3.1",
    "react-intl": "10.1.14",
    "react-json-pretty": "^2.2.0",
    "react-router-bootstrap": "^0.26.3",
    "react-router-dom": "^6.30.4",
    "urijs": "1.19.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@flydotio/dockerfile": "^0.7.10",
    "@playwright/test": "^1.61.1",
    "@remix-run/dev": "2.17.5",
    "@remix-run/testing": "2.17.5",
    "@swc/core": "1.15.43",
    "@swc/jest": "0.2.39",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "30.0.0",
    "@types/js-cookie": "^3.0.6",
    "@types/lodash": "^4.17.24",
    "@types/node": "24.13.2",
    "@types/prismjs": "^1.26.6",
    "@types/react": "18.3.27",
    "@types/react-copy-to-clipboard": "^5.0.7",
    "@types/react-dom": "18.3.7",
    "@types/react-router-bootstrap": "0.26.8",
    "@types/react-test-renderer": "^18.3.1",
    "@types/urijs": "^1.19.26",
    "@typescript-eslint/parser": "^8.62.1",
    "baseline-browser-mapping": "^2.10.41",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jest-fetch-mock": "^3.0.3",
    "jest-preview": "^0.3.3",
    "lint-staged": "^17.0.8",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.9.4",
    "react-test-renderer": "^18.3.1",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^6.4.3",
    "vite-plugin-node-polyfills": "^0.28.0",
    "vite-tsconfig-paths": "^6.1.1",
    "wrangler": "^4.107.0"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": "eslint --max-warnings=0"
  }
}
